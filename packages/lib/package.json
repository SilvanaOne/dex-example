{
  "name": "@dex-example/lib",
  "description": "DEX example library",
  "version": "0.1.0",
  "author": "DFST",
  "bugs": "https://github.com/SilvanaOne/dex-example/issues",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.13.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    "types": "./dist/node/index.d.ts",
    "node": {
      "import": "./dist/node/index.js",
      "require": "./dist/node/index.cjs"
    },
    "browser": "./dist/web/index.js",
    "default": "./dist/web/index.js"
  },
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://dex.silvana.dev",
  "keywords": [
    "cloud",
    "fungible-token",
    "mina-protocol",
    "silvana",
    "NFT",
    "proving",
    "tokens",
    "typescript"
  ],
  "license": "Apache-2.0",
  "main": "dist/web/index.js",
  "publishConfig": {
    "access": "public"
  },
  "repository": "SilvanaOne/dex-example.git",
  "scripts": {
    "build": "rm -rf dist && tsc && tsc --build tsconfig.web.json && node build-cjs.js"
  },
